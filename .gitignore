# ============================================================================
#  InternOps .gitignore
# ============================================================================

# --- Environment (NEVER commit secrets) -------------------------------------
.env
.env.local
.env.production
.env.*.local
.env.example  # commit the example
backend/.env
backend/.env.local
backend/.env.production
backend/.env.*
!backend/.env.example
!backend/.env.production.example
frontend/.env
frontend/.env.local
frontend/.env.*
!frontend/.env.example

# --- Dependencies (regenerated by `npm install`) ---------------------------
node_modules/
**/node_modules/
.pnp/
.pnp.js

# --- Build output -----------------------------------------------------------
dist/
build/
out/
.next/
.turbo/
.cache/
**/.cache/
**/.vite/
.vite/

# --- Coverage & test output -------------------------------------------------
coverage/
**/coverage/
*.lcov
*.cover
.nyc_output/

# --- Runtime upload storage (NEVER source) ----------------------------------
/backend/uploads/*
!/backend/uploads/.gitkeep
/backend/uploads/avatars/*
!/backend/uploads/avatars/.gitkeep
backend/uploads/avatars/
backend/uploads/proofs/
backend/uploads/temp/

# --- Logs --------------------------------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock
backend/logs/
internops-crash.log
server-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Secrets / credentials ---------------------------------------------------
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx
**/secrets/

# --- OS / editor / IDE cruft ------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
.vs/
.history/

# --- Diagnostics / debug scratch ---------------------------------------------
_dbtest.cjs
_dbtest.js
_dbtest
check_plugins.js
fix_async.cjs
fix_async_done.js
fix_routes.cjs
_merge_routes.cjs
_migrate_runner.cjs
backend-test-report.txt
internops-diagnostic-report.txt
*-report.txt
*-crash.log
diagnostic-report.txt

# --- Backup / merge artifacts ------------------------------------------------
*.bak
*.tmp
*.orig
*.rej
.merge
.tmp/

# --- Docker volumes ----------------------------------------------------------
postgres_data/
.docker-volumes/

# --- Project-specific ---------------------------------------------------------
InternOps/
/tmp/
tmp/
