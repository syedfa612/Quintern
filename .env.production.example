# =============================================================================
# InternOps · Production secrets
# This file is loaded by docker-compose. Do NOT commit it.
# Each secret must be a single line of text. Use openssl to generate:
#
#   openssl rand -base64 48 > secrets/jwt_access_secret.txt
#   openssl rand -base64 48 > secrets/jwt_refresh_secret.txt
#   openssl rand -base64 48 > secrets/csrf_secret.txt
#   openssl rand -base64 32 > secrets/postgres_password.txt
#
# File permissions should be 0600 (chmod 600 secrets/*).
# =============================================================================

POSTGRES_DB=internops
POSTGRES_USER=internops
POSTGRES_PASSWORD=change-me-now

# JWT — HS256, 48 random bytes each.
JWT_ACCESS_SECRET=change-me-to-48-random-bytes
JWT_REFRESH_SECRET=change-me-to-48-random-bytes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CSRF — independent from JWT so a JWT leak can't forge CSRF.
CSRF_SECRET=change-me-to-48-random-bytes

# Frontend.
APP_URL=https://internops.example.com
CORS_ORIGIN=https://internops.example.com
VITE_API_BASE=/api

# SMTP for transactional email (password resets, verification).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=internops@example.com
SMTP_PASS=change-me

# Optional: AI assistant.
ANTHROPIC_API_KEY=change-me

# Optional: Uptoskills integration.
UPTOSKILLS_BASE_URL=
UPTOSKILLS_API_KEY=
